{
  "name": "@retain/webhook-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @retain/webhook-worker^... run build",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --env-file=.env --test src/**/*.test.ts"
  },
  "dependencies": {
    "@retain/database": "workspace:*",
    "@retain/shared": "workspace:*",
    "@retain/shopify-admin": "workspace:*",
    "bullmq": "^5.13.0",
    "envalid": "^8.0.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
