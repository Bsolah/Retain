NODE_ENV=development
PORT=3001
HOST=0.0.0.0

DATABASE_URL=postgresql://retain:retain@localhost:5433/retain
REDIS_URL=redis://localhost:6380
JWT_SECRET=change-me-in-development
# 32-byte key as 64 hex chars (openssl rand -hex 32)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
# Public API URL (use your ngrok HTTPS URL in local dev)
SHOPIFY_APP_URL=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app
# Embedded admin frontend (Vite). Falls back to Shopify admin app URL when empty.
ADMIN_APP_URL=http://localhost:5173
SCOPES=read_products,write_products,read_customers,write_customers,read_orders,read_own_subscription_contracts,write_own_subscription_contracts,read_themes

# Theme app extension block handle (must match extensions/retain-purchase-options/blocks/)
THEME_EXTENSION_BLOCK_HANDLE=purchase-options

AI_SERVICE_URL=http://localhost:8000
ARCHIVE_DELETE_FROM_SHOPIFY=false
PORTAL_URL=http://localhost:5174
# App-wide Customer Account API client ID (Partner Dashboard — one value for all merchants)
CUSTOMER_ACCOUNT_CLIENT_ID=
# Optional local dev fallback when testing without ?shop= on the portal login URL
# CUSTOMER_ACCOUNT_SHOP_DOMAIN=your-store.myshopify.com

# Dunning / cancel flow messaging (dry-run when empty)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@retain.app
SENDGRID_FROM_NAME=Retain
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
