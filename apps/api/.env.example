NODE_ENV=development
PORT=3001
HOST=0.0.0.0

DATABASE_URL=postgresql://retain:retain@localhost:5433/retain
REDIS_URL=redis://localhost:6380
JWT_SECRET=change-me-in-development
# 32-byte key as 64 hex chars (openssl rand -hex 32)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
# Public API URL (use your ngrok HTTPS URL in local dev)
SHOPIFY_APP_URL=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app
# Embedded admin frontend (Vite). Falls back to Shopify admin app URL when empty.
ADMIN_APP_URL=http://localhost:5173
SCOPES=read_products,write_products,read_customers,write_customers,read_orders,read_own_subscription_contracts,write_own_subscription_contracts

AI_SERVICE_URL=http://localhost:8000
