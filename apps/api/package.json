{
  "name": "@retain/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "prebuild": "pnpm --filter @retain/api^... run build && pnpm codegen",
    "build": "tsc -p tsconfig.json && mkdir -p dist/graphql dist/templates && cp src/graphql/schema.graphql dist/graphql/schema.graphql && cp -R src/templates dist/templates",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "pnpm codegen && tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:unit && pnpm test:legacy",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.cjs --runInBand",
    "test:legacy": "node --env-file=.env --import tsx --test src/health.test.ts src/shopify-auth.test.ts src/plans.test.ts src/contracts.test.ts src/dunning-cancel.test.ts src/notifications.test.ts src/migrations.test.ts",
    "test:all": "pnpm test:unit && pnpm test:integration && pnpm test:legacy",
    "oauth:simulate": "tsx --env-file=.env scripts/simulate-oauth.ts",
    "diagnose:token": "tsx --env-file=.env scripts/diagnose-shop-token.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@retain/database": "workspace:*",
    "@retain/shared": "workspace:*",
    "@retain/shopify-admin": "workspace:*",
    "@types/handlebars": "^4.1.0",
    "bullmq": "^5.13.0",
    "envalid": "^8.0.0",
    "fastify": "^4.28.1",
    "graphql": "16.14.2",
    "handlebars": "^4.7.9",
    "ioredis": "^5.4.1",
    "mercurius": "^14.1.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.9",
    "@graphql-codegen/typescript-resolvers": "^4.2.1",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.16.5",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nock": "^13.5.6",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-jest-resolver": "^2.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
