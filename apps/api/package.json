{
  "name": "@retain/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "prebuild": "pnpm codegen",
    "build": "tsc -p tsconfig.json && mkdir -p dist/graphql && cp src/graphql/schema.graphql dist/graphql/schema.graphql",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "pnpm codegen && tsc -p tsconfig.json --noEmit",
    "test": "node --env-file=.env --import tsx --test src/health.test.ts src/shopify-auth.test.ts",
    "oauth:simulate": "tsx --env-file=.env scripts/simulate-oauth.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@retain/database": "workspace:*",
    "@retain/shared": "workspace:*",
    "bullmq": "^5.13.0",
    "envalid": "^8.0.0",
    "fastify": "^4.28.1",
    "graphql": "16.14.2",
    "ioredis": "^5.4.1",
    "mercurius": "^14.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/typescript": "^4.0.9",
    "@graphql-codegen/typescript-resolvers": "^4.2.1",
    "@types/node": "^20.16.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
