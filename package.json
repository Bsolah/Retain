{
  "name": "retain",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "pnpm --filter @retain/api test:integration",
    "test:e2e": "pnpm --filter @retain/e2e test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check",
    "db:generate": "pnpm --filter @retain/database generate",
    "postinstall": "pnpm db:generate",
    "db:migrate": "pnpm --filter @retain/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @retain/database migrate:deploy",
    "db:push": "pnpm --filter @retain/database push",
    "db:seed": "pnpm --filter @retain/database seed",
    "shopify:deploy": "shopify app deploy --allow-updates",
    "shopify:deploy:production-urls": "bash scripts/deploy-shopify-production-urls.sh",
    "build:railway:api": "pnpm db:generate && pnpm --filter @retain/api... build",
    "build:railway:webhook-worker": "pnpm db:generate && pnpm --filter @retain/webhook-worker... build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "graphql": "16.14.2"
    }
  }
}
