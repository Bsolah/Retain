{% comment %}
  Retain purchase options — simple selector for all themes:
  radio · plan name · delivery frequency (subtext) · price
  One row per selling plan allocation (each frequency / plan).
{% endcomment %}

{%- assign current_variant = product.selected_or_first_available_variant | default: product.variants.first -%}
{%- assign retain_app_id = block.settings.retain_app_id | default: 'retain' -%}

{% if product.selling_plan_groups.size > 0 %}
  <div
    class="retain-purchase-options selling_plan_app_container"
    data-retain-purchase-options
    data-section-id="{{ section.id }}"
    data-hide-native-selling-plans="true"
    {{ block.shopify_attributes }}
  >
    {% if block.settings.heading != blank %}
      <p class="retain-purchase-options__heading">{{ block.settings.heading }}</p>
    {% endif %}

    {% for variant in product.variants %}
      {% liquid
        assign variant_price = variant.price | money | escape
        assign variant_compare_at_price = variant.compare_at_price | money | escape
      %}

      {% if variant.selling_plan_allocations.size > 0 %}
        <section
          data-variant-id="{{ variant.id }}"
          class="retain-purchase-options__variant selling_plan_theme_integration{% unless variant.id == current_variant.id %} selling_plan_theme_integration--hidden retain-purchase-options--hidden{% endunless %}"
        >
          <fieldset class="retain-purchase-options__fieldset">
            <legend class="retain-purchase-options__legend">
              {{ block.settings.heading | default: 'Purchase options' }}
            </legend>

            <ul class="retain-purchase-options__list">
              {% unless product.requires_selling_plan %}
                <li class="retain-purchase-options__item">
                  <label class="retain-purchase-options__option">
                    <input
                      type="radio"
                      name="purchaseOption_{{ section.id }}_{{ variant.id }}"
                      data-radio-type="one_time_purchase"
                      data-variant-id="{{ variant.id }}"
                      data-variant-price="{{ variant_price }}"
                      data-variant-compare-at-price="{{ variant_compare_at_price }}"
                      {% if variant.available == false %}disabled{% endif %}
                      checked
                    />
                    <span class="retain-purchase-options__copy">
                      <span class="retain-purchase-options__label">
                        {{ block.settings.one_time_label | default: 'One-time purchase' }}
                      </span>
                    </span>
                    <span class="retain-purchase-options__price">{{ variant_price }}</span>
                  </label>
                </li>
              {% endunless %}

              {% assign rendered_retain_plans = 0 %}
              {% for allocation in variant.selling_plan_allocations %}
                {% liquid
                  assign group = product.selling_plan_groups | where: 'id', allocation.selling_plan_group_id | first
                  assign show_plan = false
                  if group != nil and group.app_id == retain_app_id
                    assign show_plan = true
                  endif
                %}

                {% if show_plan %}
                  {% liquid
                    if rendered_retain_plans == 0 and product.requires_selling_plan
                      assign plan_checked = 'checked'
                    else
                      assign plan_checked = nil
                    endif
                    assign rendered_retain_plans = rendered_retain_plans | plus: 1

                    assign allocation_price = allocation.price | money | escape
                    assign allocation_compare_at_price = allocation.compare_at_price | money | escape
                    assign plan_name = allocation.selling_plan.name
                    assign plan_name_parts = plan_name | split: ' — '
                    if plan_name_parts.size > 1
                      assign option_label = plan_name_parts.first
                    else
                      assign option_label = group.name
                    endif
                  %}

                  {%- assign delivery_frequency = '' -%}
                  {%- for option in allocation.selling_plan.options -%}
                    {%- assign delivery_frequency = option.value -%}
                  {%- endfor -%}

                  {% liquid
                    if delivery_frequency == blank and plan_name_parts.size > 1
                      assign delivery_frequency = plan_name_parts.last
                    endif

                    if delivery_frequency != blank
                      assign delivery_label = 'Delivers every ' | append: delivery_frequency | downcase
                    else
                      assign delivery_label = ''
                    endif
                  %}

                  <li class="retain-purchase-options__item" data-retain-plan-group>
                    <label class="retain-purchase-options__option">
                      <input
                        type="radio"
                        name="purchaseOption_{{ section.id }}_{{ variant.id }}"
                        data-radio-type="selling_plan"
                        data-selling-plan-id="{{ allocation.selling_plan.id }}"
                        data-selling-plan-name="{{ allocation.selling_plan.name | escape }}"
                        data-frequency="{{ delivery_frequency | escape }}"
                        data-group-name="{{ group.name | escape }}"
                        data-selling-plan-group-id="{{ section.id }}_{{ allocation.selling_plan_group_id }}_{{ variant.id }}"
                        data-variant-price="{{ allocation_price }}"
                        data-variant-compare-at-price="{{ allocation_compare_at_price }}"
                        data-delivery-label="{{ delivery_label | escape }}"
                        data-option-label="{{ option_label | escape }}"
                        aria-label="{{ option_label }}{% if delivery_label != blank %}. {{ delivery_label }}{% endif %}. {{ allocation_price }}"
                        {% if variant.available == false %}disabled{% endif %}
                        {{ plan_checked }}
                      />
                      <span class="retain-purchase-options__copy">
                        <span class="retain-purchase-options__label" data-retain-option-label>
                          {{ option_label }}
                        </span>
                        {% if delivery_label != blank %}
                          <span class="retain-purchase-options__subtext" data-retain-delivery-label>
                            {{ delivery_label }}
                          </span>
                        {% endif %}
                      </span>
                      <span class="retain-purchase-options__price" data-retain-option-price>
                        {{ allocation_price }}
                      </span>
                    </label>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </fieldset>
        </section>
      {% endif %}
    {% endfor %}

    <input
      type="hidden"
      name="selling_plan"
      class="retain-selected-selling-plan-id selected-selling-plan-id"
      value=""
    />
  </div>
{% endif %}

{% schema %}
{
  "name": "Retain: Subscribe",
  "target": "section",
  "templates": ["product"],
  "stylesheet": "retain-purchase-options.css",
  "javascript": "retain-purchase-options.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Purchase options"
    },
    {
      "type": "text",
      "id": "one_time_label",
      "label": "One-time purchase label",
      "default": "One-time purchase"
    },
    {
      "type": "text",
      "id": "retain_app_id",
      "label": "Retain app identifier",
      "default": "retain",
      "info": "Only selling plan groups created by Retain are shown. Do not change unless support asks you to."
    }
  ]
}
{% endschema %}
